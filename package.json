{
  "name": "dougmarch",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.14.0",
  "imports": {
    "#/*": "./app/*"
  },
  "scripts": {
    "dev": "panda codegen && vite",
    "build": "panda codegen && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:e2e:site": "playwright test --project=site-health",
    "test:e2e:dev": "playwright test --project=dev-panel",
    "test:e2e": "playwright test",
    "codegen": "panda codegen",
    "codegen:watch": "panda codegen --watch",
    "pipeline": "MOCK_MODE=true node scripts/run-pipeline.js",
    "pipeline:dry": "MOCK_MODE=true DRY_RUN=true node scripts/run-pipeline.js",
    "pipeline:collect": "node scripts/collect-signals.js",
    "pipeline:interpret": "MOCK_MODE=true node scripts/interpret-signals.js"
  },
  "dependencies": {
    "@tanstack/react-devtools": "latest",
    "@tanstack/react-router": "latest",
    "@tanstack/react-router-devtools": "latest",
    "@tanstack/react-start": "latest",
    "@tanstack/start-api-routes": "^1.120.19",
    "js-yaml": "^4.1.1",
    "lucide-react": "^1.7.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.85.0",
    "@pandacss/dev": "^1.9.1",
    "@playwright/test": "^1.59.1",
    "@tanstack/devtools-vite": "latest",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5",
    "dotenv": "^17.4.1",
    "jsdom": "^29.0.2",
    "typescript": "^5",
    "vite": "^7",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss"
    ],
    "overrides": {
      "picomatch": ">=4.0.4",
      "brace-expansion": ">=5.0.5",
      "h3": ">=2.0.1-rc.18",
      "h3-v2": "npm:h3@>=2.0.1-rc.18",
      "defu": ">=6.1.5",
      "lodash": ">=4.18.0",
      "srvx": ">=0.11.13",
      "serialize-javascript": ">=7.0.3",
      "undici": ">=7.24.0",
      "node-forge": ">=1.4.0",
      "path-to-regexp": ">=8.4.0",
      "esbuild": ">=0.25.0"
    }
  }
}
